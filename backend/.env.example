# Copy this file to .env and fill in your local values.

# MySQL
DB_URL=jdbc:mysql://localhost:3306/app?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_ROOT_PASSWORD=replace-me-root-password
MYSQL_DATABASE=app
MYSQL_USER=replace-me-db-user
MYSQL_PASSWORD=replace-me-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-me-redis-password
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Optional storage (enable with docker-compose.storage.yml)
# MINIO_ROOT_USER=replace-me-minio-user
# MINIO_ROOT_PASSWORD=replace-me-minio-password

SPRING_APPLICATION_NAME=backend

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-bytes

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@example.com

# App
APP_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=ko
APP_NAME=application
CORS_ALLOWED_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
SWAGGER_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_AGE_DAYS=7
UNVERIFIED_MEMBER_CLEANUP_CRON=0 0 3 * * *
ORDER_TIMEOUT_ENABLED=true
ORDER_TIMEOUT_CRON=0 * * * * *
APP_INVENTORY_MODE=redis #db-lock/redis 선택
APP_INVENTORY_REDIS_SYNC_DELAY_MS=1000
APP_PAYMENT_KAFKA_ENABLED=true
APP_PAYMENT_KAFKA_TOPIC=payment-result.v1
APP_PAYMENT_KAFKA_CONSUMER_GROUP=order-payment-result
APP_PAYMENT_KAFKA_PUBLISHER_DELAY_MS=500
APP_PAYMENT_KAFKA_PUBLISHER_BATCH_SIZE=100
APP_PAYMENT_KAFKA_MAX_ATTEMPTS=20

# Toss Payments
TOSS_SECRET_KEY=REPLACE_ME_TEST_SECRET_KEY
TOSS_CLIENT_KEY=REPLACE_ME_TEST_CLIENT_KEY
TOSS_BASE_URL=https://api.tosspayments.com

# OAuth (optional)
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
NAVER_CLIENT_ID=REPLACE_ME
NAVER_CLIENT_SECRET=REPLACE_ME
KAKAO_CLIENT_ID=REPLACE_ME
KAKAO_CLIENT_SECRET=REPLACE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
