# Copy this file to .env and fill in your local values.
# This file is loaded by Spring Boot via `spring.config.import`
# and by Docker Compose via `env_file`.

# MySQL
DB_URL=jdbc:mysql://localhost:3306/app?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_ROOT_PASSWORD=replace-me-root-password
MYSQL_DATABASE=app
MYSQL_USER=replace-me-db-user
MYSQL_PASSWORD=replace-me-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-me-redis-password

# Optional storage (enable with docker-compose.storage.yml)
# MINIO_ROOT_USER=replace-me-minio-user
# MINIO_ROOT_PASSWORD=replace-me-minio-password

SPRING_APPLICATION_NAME=backend

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-bytes

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@example.com

# App
APP_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=ko
APP_NAME=application
CORS_ALLOWED_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
SWAGGER_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_AGE_DAYS=7
UNVERIFIED_MEMBER_CLEANUP_CRON=0 0 3 * * *

# OAuth (optional)
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
NAVER_CLIENT_ID=REPLACE_ME
NAVER_CLIENT_SECRET=REPLACE_ME
KAKAO_CLIENT_ID=REPLACE_ME
KAKAO_CLIENT_SECRET=REPLACE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
